{
  "manifest_version": 3,
  "name": "VGTunes Dashboard Extension",
  "version": "0.1",

  "description": "Extension for adding features to the VGTunes dashboard",

  "icons": {
    "48": "icons/border-48.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "@dev.chsxf.vgtunes.dashboard-browser-extension"
    }
  },

  "permissions": ["menus", "scripting", "tabs", "clipboardWrite"],

  "host_permissions": ["https://*.bandcamp.com/*"],

  "background": {
    "scripts": ["extension.js"]
  },

  "commands": {
    "copy-bandcamp-platform-id": {
      "suggested_key": { "default": "Ctrl+Alt+B" },
      "description": "Generate platform Id on Bandcamp"
    }
  }
}
