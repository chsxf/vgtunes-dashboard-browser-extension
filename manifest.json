{
  "manifest_version": 3,
  "name": "VGTunes Dashboard Extension",
  "version": "0.1",

  "description": "Extension for adding features to the VGTunes dashboard",

  "icons": {
    "48": "icons/border-48.png"
  },

  "browser_specific_settings": {
    "gecko": {}
  },

  "permissions": ["menus", "scripting", "tabs"],

  "host_permissions": ["https://*.bandcamp.com/*"],

  "background": {
    "scripts": ["extension.js"]
  }
}
